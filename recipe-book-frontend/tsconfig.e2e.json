{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "types": ["node", "@playwright/test"],
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "noEmit": true
    },
    "include": [
        "playwright.config.ts",
        "e2e/**/*.ts"
    ]
}